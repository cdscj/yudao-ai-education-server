# ========================================
# Yudao AI 模块 - 环境变量配置示例
# 复制此文件为 .env 并填入真实值
# ========================================

# ---------- AI 模型 API Keys ----------
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
ANTHROPIC_API_KEY=sk-your-anthropic-key
GEMINI_API_KEY=your-gemini-key
DEEPSEEK_API_KEY=sk-your-deepseek-key
QIANFAN_API_KEY=your-baidu-qianfan-key
QIANFAN_SECRET_KEY=your-baidu-qianfan-secret
ZHIPUAI_API_KEY=your-zhipuai-key
DASHSCOPE_API_KEY=sk-your-dashscope-key
SILICONFLOW_API_KEY=sk-your-siliconflow-key
STABILITYAI_API_KEY=sk-your-stability-key
DOUBAO_API_KEY=your-doubao-key
MINIMAX_API_KEY=your-minimax-key
MOONSHOT_API_KEY=sk-your-moonshot-key
HUNYUAN_API_KEY=your-hunyuan-key
BAICHUAN_API_KEY=your-baichuan-key
XINGHUO_APP_KEY=your-xinghuo-app-key
XINGHUO_SECRET_KEY=your-xinghuo-secret
MIDJOURNEY_API_KEY=sk-your-midjourney-key
MIDJOURNEY_BASE_URL=https://your-midjourney-proxy
MIDJOURNEY_NOTIFY_URL=http://your-domain/admin-api/ai/image/midjourney/notify
SUNO_BASE_URL=http://your-suno-api
WEB_SEARCH_API_KEY=your-web-search-key
IFLYTEK_API_KEY=your-iflytek-api-key

# ---------- 数据库 ----------
DB_PASSWORD=your-database-password

# ---------- 应用配置 ----------
ADMIN_UI_URL=http://localhost:48080
AES_ENCRYPT_KEY=your-aes-encrypt-key

# ---------- 向量存储 ----------
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6334
